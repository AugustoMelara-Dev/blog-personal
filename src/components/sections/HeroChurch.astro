---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import { churchInfo } from "../../data/site";

// Procesamiento de horarios para dar prioridad al servicio sabático
const isSabbath = (str: string) => str.toLowerCase().includes("sába") || str.toLowerCase().includes("saba");
const sabbathServices = churchInfo.serviceTimes.filter(s => isSabbath(s.name) || isSabbath(s.schedule));
const otherServices = churchInfo.serviceTimes.filter(s => !isSabbath(s.name) && !isSabbath(s.schedule));

const mainService = sabbathServices.length > 0 ? sabbathServices : churchInfo.serviceTimes.slice(0, 1);
const secondaryServices = otherServices.length > 0 ? otherServices : churchInfo.serviceTimes.slice(1);
---

<section class="bg-paper flex flex-col pt-8 md:pt-16 border-b border-brand-100 overflow-hidden">
  <Container class="pb-12 md:pb-24">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">
      
      <!-- Text Content: Contained, legible, strong hierarchy -->
      <div class="max-w-xl md:pr-10">
        <div class="inline-flex items-center gap-3 mb-8">
           <span class="w-10 h-[2px] bg-brand-700"></span>
           <span class="text-xs font-bold uppercase tracking-[0.15em] text-brand-800">Bienvenido a su casa</span>
        </div>
        
        <!-- Prevent cutoff by utilizing tracking-tight and contained leading -->
        <h1 class="font-serif text-[2.75rem] md:text-5xl lg:text-[4rem] font-bold leading-[1.1] text-ink-900 text-balance mb-6">
          {churchInfo.heroTitle}
        </h1>
        
        <p class="text-lg md:text-xl text-ink-600 leading-relaxed mb-10 text-pretty">
          {churchInfo.tagline} {churchInfo.visitNote && <span class="block mt-3 text-base text-ink-500 font-medium">{churchInfo.visitNote}</span>}
        </p>
        
        <div class="flex flex-wrap items-center gap-4">
          <Button href="/visitanos" size="lg">Planifica tu visita</Button>
          <a href="/ministerios" class="inline-flex items-center justify-center font-semibold text-lg text-ink-600 hover:text-brand-800 px-6 py-3 transition-colors group">
            Conocer Comunidad <span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300 ml-1">&rarr;</span>
          </a>
        </div>
      </div>
      
      <!-- Image Content: Realistic Church/Bible Visual (No weird graphics) -->
      <div class="relative w-full aspect-[4/3] md:aspect-video lg:aspect-[4/3] rounded-[2rem] overflow-hidden shadow-[0_15px_40px_rgba(36,80,122,0.12)] border border-brand-100">
        <img 
          src="https://images.unsplash.com/photo-1544427920-c49ccdaf8c2d?q=80&w=1200&auto=format&fit=crop" 
          alt="Palabra de Dios compartida en la iglesia" 
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-[3000ms] hover:scale-105" 
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
        <!-- Subtle warm institutional overlay -->
        <div class="absolute inset-0 bg-brand-900/10 mix-blend-overlay"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        
        <!-- Promesa for the day integrated gracefully at the bottom of the photo -->
        <div class="absolute bottom-0 left-0 right-0 p-8 sm:p-10 pointer-events-none">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-brand-100 mb-2 opacity-90 drop-shadow-md">Promesa Diaria</p>
          <blockquote class="font-serif italic text-xl sm:text-2xl text-white drop-shadow-md leading-snug">
            "{churchInfo.heroScripture}"
          </blockquote>
        </div>
      </div>

    </div>
  </Container>

  <!-- Horarios de Adoración - Integrated Solidly, Sabbath Focus -->
  <div class="bg-white border-t border-brand-100 py-12 lg:py-16 relative z-10 w-full">
    <Container>
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-16 items-start lg:items-center">
         
         <div class="lg:w-1/3">
           <h2 class="font-serif text-3xl font-bold text-brand-900 mb-3">Horarios de Culto</h2>
           <p class="text-ink-600 leading-relaxed text-sm">El momento perfecto para renovar tu fe en esperanza y convicción adventista.</p>
         </div>

         <div class="col-span-1 border-t lg:border-t-0 lg:border-l border-brand-100 w-full lg:w-[1px] h-[1px] lg:h-24"></div>

         <div class="lg:w-2/3 grid sm:grid-cols-2 gap-6 w-full">
            <!-- Primera Prioridad: Sábado Día del Señor -->
            <div class="bg-paper rounded-2xl p-6 border-l-[6px] border-l-brand-700 shadow-sm transition-transform hover:-translate-y-1">
               <div class="flex items-center gap-3 mb-4">
                  <span class="bg-brand-100 text-brand-900 text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded">Día Principal</span>
               </div>
               
               <div class="space-y-3">
                 {mainService.map(service => (
                    <div class="flex flex-col sm:flex-row sm:justify-between items-start sm:items-baseline border-b border-brand-100 pb-2 last:border-0 last:pb-0">
                      <span class="font-semibold text-ink-900">{service.name}</span>
                      <strong class="text-brand-800 text-lg sm:text-right">{service.schedule}</strong>
                    </div>
                 ))}
               </div>
            </div>

            <!-- Secundaria: Eventos entre semana -->
            <div class="bg-white rounded-2xl p-6 border border-brand-100">
               <p class="text-xs font-bold uppercase tracking-widest text-ink-400 mb-4">Eventos Semanales</p>
               <div class="space-y-3">
                 {secondaryServices.map(service => (
                    <div class="flex flex-col sm:flex-row sm:justify-between items-start sm:items-baseline border-b border-brand-50 pb-2 last:border-0 last:pb-0">
                       <span class="text-sm text-ink-600 font-medium">{service.name}</span>
                       <span class="text-brand-700 bg-brand-50 px-2 py-0.5 rounded text-sm sm:text-right font-semibold">{service.schedule}</span>
                    </div>
                 ))}
               </div>
            </div>
         </div>

      </div>
    </Container>
  </div>
</section>
