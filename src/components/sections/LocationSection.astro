---
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import Button from "../ui/Button.astro";
import { churchInfo, isExternalUrl, isPendingValue } from "../../data/site";
---

<Section>
  <Container>
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <SectionHeading
          kicker="Ubicacion"
          title="Informacion practica para llegar al templo"
          description={churchInfo.addressLine2 ? `${churchInfo.address} · ${churchInfo.addressLine2}` : churchInfo.address}
        />
        <p class="mt-6 text-ink-600">{churchInfo.visitNote}</p>
        {churchInfo.reference && <p class="mt-3 text-sm text-ink-500">Referencia: {churchInfo.reference}</p>}
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/ubicacion">Ver ubicacion</Button>
          {
            isExternalUrl(churchInfo.mapUrl) && !isPendingValue(churchInfo.mapUrl) && (
              <Button href={churchInfo.mapUrl} variant="secondary">
                Abrir en mapa
              </Button>
            )
          }
        </div>
      </div>
      {
        isPendingValue(churchInfo.mapUrl) || isPendingValue(churchInfo.address) ? (
          <div class="card flex min-h-[360px] items-center justify-center text-center">
            <div>
              <h3 class="font-serif text-2xl text-ink-900">Ubicacion detallada pendiente</h3>
              <p class="mt-4 max-w-md text-ink-600">
                Muy pronto encontraras aqui la direccion exacta, la referencia de llegada y el acceso directo al mapa.
              </p>
            </div>
          </div>
        ) : (
          <div class="overflow-hidden rounded-[2rem] border border-brand-100 shadow-soft">
            <iframe
              title="Mapa de la iglesia"
              src={`https://www.google.com/maps?q=${encodeURIComponent(churchInfo.mapQuery)}&output=embed`}
              class="h-[360px] w-full"
              loading="lazy"
            ></iframe>
          </div>
        )
      }
    </div>
  </Container>
</Section>
