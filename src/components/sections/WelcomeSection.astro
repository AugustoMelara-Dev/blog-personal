---
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import { homeHighlights } from "../../data/site";
---

<Section class="bg-paper relative overflow-hidden">
  <!-- Subtle decorative element to add depth -->
  <div class="absolute right-0 top-0 w-1/3 aspect-square bg-brand-50 rounded-full blur-[100px] opacity-60 -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="inline-flex items-center justify-center gap-3 mb-6">
         <span class="w-8 h-[1px] bg-brand-700"></span>
         <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-brand-800">Bienvenidos</span>
         <span class="w-8 h-[1px] bg-brand-700"></span>
      </div>
      <h2 class="font-serif text-3xl md:text-5xl font-bold text-ink-900 leading-[1.1] mb-6 text-balance">
        Un sitio pensado para comunicar con claridad lo esencial de la iglesia.
      </h2>
      <p class="text-lg md:text-xl text-ink-600 leading-relaxed text-pretty">
        Aquí la información importante está organizada para miembros, visitas y personas interesadas en conocer más de la fe adventista.
      </p>
    </div>

    <div class="grid gap-6 md:gap-8 lg:grid-cols-3">
      {
        homeHighlights.map((item) => (
          <div class="group bg-white rounded-3xl p-8 sm:p-10 shadow-sm border border-brand-50 hover:shadow-[0_20px_40px_rgba(36,80,122,0.08)] hover:-translate-y-2 transition-all duration-400 ease-out cursor-pointer relative overflow-hidden">
            <div class="absolute top-0 right-0 p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-brand-200">
               <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
            
            <h3 class="font-serif text-2xl font-bold text-brand-900 leading-tight mb-4 group-hover:text-brand-700 transition-colors">{item.title}</h3>
            <p class="text-ink-600 leading-relaxed">{item.description}</p>
          </div>
        ))
      }
    </div>
  </Container>
</Section>
