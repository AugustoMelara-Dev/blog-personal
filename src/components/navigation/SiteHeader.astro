---
import { churchInfo, navigation, utilityNavigation } from "../../data/site";
import MainNav from "./MainNav.astro";
import MobileNav from "./MobileNav";
import Button from "../ui/Button.astro";
import ChurchLogo from "../branding/ChurchLogo.astro";
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-md shadow-sm border-b border-brand-100">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-4 md:py-6 lg:px-8">
    <a href="/" class="flex flex-1 min-w-0 items-center gap-4 group">
      <!-- Unaltered Church Logo (Removed the weird boxing and rounded border) -->
      <ChurchLogo variant="mark" class="w-10 h-10 md:w-14 md:h-14 flex-shrink-0" />
      <div class="min-w-0 flex flex-col justify-center border-l border-brand-200 pl-4 py-1">
        <!-- Official Name clear and legible, Noto Serif -->
        <p class="font-serif text-lg md:text-xl font-bold text-brand-900 leading-[1.1] mb-1" translate="no">
          {churchInfo.name}
        </p>
        <p class="truncate text-[10px] md:text-xs font-bold uppercase tracking-[0.1em] text-brand-600" translate="no">
          {churchInfo.localIdentifier}
        </p>
      </div>
    </a>

    <div class="hidden xl:flex items-center justify-center">
      <MainNav />
    </div>

    <!-- Clear, inviting CTA -->
    <div class="hidden items-center justify-end flex-[0.8] gap-5 xl:flex">
      <a href="/buscar" class="text-sm font-semibold text-ink-600 hover:text-brand-800 transition-colors">Buscar</a>
      <Button href="/visitanos" variant="primary" class="shadow-sm">Visítanos este Sábado</Button>
    </div>

    <MobileNav client:load items={[...navigation, ...utilityNavigation]} pathname={Astro.url.pathname} />
  </div>
</header>
